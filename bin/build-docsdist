#!/usr/bin/env bash
# officraft — stage the product-guide docs for the single binary.
#
# The repo-root README.md + docs/guide/ tree (the product feature docs — the
# single source read by the Settings 使用說明 sub-page AND Mira's get_doc MCP
# tool) sit outside the server module, and go:embed cannot reach outside the
# module directory, so a doc-carrying ocserverd needs them COPIED into
# server/ocserverd/docsdist/ (gitignored except .gitkeep) before `go build` —
# the exact seedsdist/webdist staging pattern. Doc reads are EMBED-ONLY
# (assets.go — no disk fallback), so WITHOUT this staging step the binary still
# builds but boots with an EMPTY doc embed (every doc read 404s). Any
# build/test that boots the server must stage first (bin/build, bin/ci.sh,
# conformance/run.sh all do).
#
# SCOPE (owner ruling: 打包 README + docs/guide): the repo-root README.md
# (staged as readme.md → slug "readme") PLUS every *.md AND the assets/ image
# tree under docs/guide/, copied whole (glob/recursive, no filename enumeration,
# so O-46's why/tasks/install/mobile.md are collected automatically). docs/dev.md
# and docs/design/ are DEVELOPER material and are NEVER shipped. The embed guard
# (api_docs_test.go) pins the staged .md set == {readme} ∪ docs/guide/*.md so a
# stray draft dropped under docs/guide is caught, not silently fed to users.
#
#   bash bin/build-docsdist           # stage README + docs/guide/ into docsdist/
#   (cd server/ocserverd && go build) # then bakes the docs into the binary
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

DOCSDIST="$ROOT/server/ocserverd/docsdist"
GUIDE="$ROOT/docs/guide"
rm -rf "$DOCSDIST"
mkdir -p "$DOCSDIST"
touch "$DOCSDIST/.gitkeep"
# docs/guide/ may not exist yet on some checkout — the .gitkeep-only state is a
# valid clean-checkout skeleton the `all:` embed tolerates.
if [[ -d "$GUIDE" ]]; then
  # Copy the whole tree (all *.md + assets/) preserving structure.
  cp -R "$GUIDE/." "$DOCSDIST/"
fi
# The repo README is the guide's front page — staged as readme.md (slug "readme").
if [[ -f "$ROOT/README.md" ]]; then
  cp "$ROOT/README.md" "$DOCSDIST/readme.md"
fi
echo "[build-docsdist] staged README + docs/guide → server/ocserverd/docsdist ($(find "$DOCSDIST" -type f -name '*.md' | wc -l | tr -d ' ') docs, $(find "$DOCSDIST" -type f ! -name '*.md' ! -name '.gitkeep' | wc -l | tr -d ' ') assets)"
